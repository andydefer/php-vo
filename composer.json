{
    "name": "andydefer/php-vo",
    "description": "A collection of reusable Value Objects and Enums for PHP applications (Email, Money, Address, PostalCode, Iso8601DateTime, Currency, etc.)",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Andy Defer",
            "email": "andykanidimbu@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "andydefer/domain-structures": "^1.23.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0",
        "mockery/mockery": "^1.6",
        "laravel/pint": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "AndyDefer\\PhpVo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AndyDefer\\PhpVo\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
